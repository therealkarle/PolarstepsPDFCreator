{
  // --- Font Settings ---
  // Font size for the step title (e.g., "1. Amsterdam")
  "step_title_font_size": 18,
  // Font size for the step description text
  "step_text_font_size": 12,
  // Main text font path (fallback to default if not found)
  "text_font_path": "C:/Windows/Fonts/SegoeUI.ttf",
  // Emoji font path (used for rendering emojis in text)
  "emoji_font_path": "C:/Windows/Fonts/seguiemj.ttf",
  // Scale factor for emojis relative to text size
  "emoji_scale": 1.2,

  // --- Layout Settings ---
  // Page margin in millimeters
  "safety_margin_mm": 12,
  // Maximum number of photos to display per step page
  "max_photos_per_step": 6,

  // --- General Map Settings ---
  // Default zoom level if no specific bounds are calculated
  "default_map_zoom": 12,
  // Minimum allowed zoom level (prevents zooming out too far)
  "min_map_zoom": 6,
  // Maximum allowed zoom level (prevents zooming in too close)
  "max_map_zoom": 16,
  // Resolution scale for map tiles (2.0 = high dpi / retina quality)
  "map_render_scale": 2.0,
  // Size of the circular photo markers in pixels (before scaling)
  "marker_thumb_size": 40,

  // --- Step Map Zoom/Padding (Advanced) ---
  // Number of Zoom levels to zoom out from the calculated fit (0 = exact fit)
  "step_map_zoom_out": 0,
  // Fraction of padding around the step bounds (0.06 = 6% margin)
  "step_map_padding": 0.06,

  // Auto-tighten padding for trips with many steps
  "step_map_auto_tighten": true,
  // Padding scale for short trips (21-40 steps)
  "step_map_tighten_scale_small": 0.8,
  // Padding scale for medium trips (41-80 steps)
  "step_map_tighten_scale_medium": 0.6,
  // Padding scale for long trips (>80 steps)
  "step_map_tighten_scale_large": 0.5,

  // --- Step Map Constraints ---
  // Ignore prev/next steps if they are further away than this (km)
  "step_map_neighbor_max_km": 600.0,
  // Only apply neighbor limit if trip has more than N steps
  "step_map_neighbor_limit_steps_threshold": 5,
  // Maximum absolute padding in km (limits padding on wide maps)
  "step_map_max_pad_km": 25.0,
  "step_map_min_width_km": 50.0, 
  // Maximum width of the map area in km (forces zoom-in if route is wider)
  "step_map_max_width_km": 750,
  // Cluster nearby steps: if neighbors are within X km, skip them for bounds calculation
  "step_cluster_radius_km": 4.0,

  // Weight centering towards current step (vs neighbors)
  "step_center_weight_current": 2.0,
  "step_center_weight_other": 1.0,

  // --- Overview Map Constraints ---
  // Padding fraction for the full trip overview map
  "overview_map_padding": 0.02,
  "overview_padding_percent": 0.01,
  "overview_force_zoom_out_when_padding": false,
  "overview_min_pad_px": 12,

  // --- App Behavior ---
  // List already rendered trips in the CLI menu
  "show_rendered_trips": true,
  // Open the generated PDF automatically after rendering
  "open_pdf_after_render": true
}
